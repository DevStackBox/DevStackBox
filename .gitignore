# Logs and runtime data only
logs/*.log
logs/*.err
logs/*.pid
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime data and processes
*.pid
*.pid.lock

# Node modules and build outputs
node_modules/
dist/
dist-ssr/
*.local
package-lock.json

# Generated logo assets (source: docs/images/logo/)
public/logo.svg
public/logo-dark.svg
public/favicon.ico

# Environment variable files - never commit secrets
.env
.env.local
.env.*.local
.env.development
.env.production

# Rust/Tauri build artifacts
src-tauri/target/

# Release artifacts (generated by scripts)
release/
release/*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS generated files
Thumbs.db
ehthumbs.db
Desktop.ini

# MySQL runtime data ONLY (keep all binaries)
mysql/data/
mysql/logs/

# Apache runtime logs ONLY (keep all binaries)
apache/logs/

# PHP runtime files ONLY (keep all binaries)
php/*/tmp/
php/*/sessions/
php/sessions/
php/current

# Backup and temp files
*.backup
*.bak
*~
*.tmp
*.temp
tmp/*

# phpMyAdmin runtime files ONLY (keep all binaries)
phpmyadmin/tmp/
phpmyadmin/upload/
phpmyadmin/save/
phpmyadmin/config.secret.inc.php

# Application runtime data
www/tmp/
www/cache/
www/uploads/
www/storage/
www/*/cache/
www/*/logs/
www/*/storage/logs/
www/*/storage/framework/cache/
www/*/storage/framework/sessions/
www/*/storage/framework/views/

# WordPress specific runtime
www/*/wp-content/uploads/
www/*/wp-content/cache/
www/*/wp-config.php

# Laravel specific runtime
www/*/.env
www/*/storage/logs/
www/*/bootstrap/cache/

# Temporary build copies (created by prepare-binaries script)
src-tauri/apache/
src-tauri/mysql/
src-tauri/php/
src-tauri/phpmyadmin/
src-tauri/www/
src-tauri/config/
apache-backup-32bit/*
/php/8.4
/php/8.2
/php/8.1
www/index.html
